<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AstroForge.App.ViewModels"
        xmlns:local="using:AstroForge.CrossPlatform.Controls"
        x:Class="AstroForge.CrossPlatform.MainWindow"
        x:CompileBindings="False"
        Title="AstroProject Forge" Icon="/Assets/astroforge.ico" Width="1280" Height="760" MinWidth="900" MinHeight="620" WindowState="Maximized"
        WindowStartupLocation="CenterScreen">
  <Grid x:Name="RootLayout" RowDefinitions="64,*">
    <Border Background="#0A1019" BorderBrush="#243146" BorderThickness="0,0,0,1" Padding="18,0">
      <Grid x:Name="HeaderGrid" ColumnDefinitions="390,*,410" VerticalAlignment="Center" ClipToBounds="True">
        <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center">
          <Border Width="38" Height="38" CornerRadius="12" Background="#153B39"><TextBlock Text="✦" Foreground="#49D9CA" FontSize="21" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
          <StackPanel><TextBlock Text="ASTROPROJECT FORGE" FontWeight="Bold" FontSize="16"/><TextBlock Text="CALIBRATION WORKSPACE" Classes="eyebrow" FontSize="9"/></StackPanel>
        </StackPanel>
        <TextBlock Grid.Column="1" Text="{Binding ProjectDocumentStatus}" Classes="muted" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="260" TextTrimming="CharacterEllipsis"/>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
          <Button Content="☰" ToolTip.Tip="Mostra o nascondi sorgenti" Click="ToggleSources_Click"/>
          <Button Content="Apri" Click="OpenProject_Click"/>
          <Button Content="Salva" Click="SaveProject_Click"/>
          <Button Content="⚙" ToolTip.Tip="Impostazioni" Click="ToggleSettings_Click"/>
          <Button Content="Analizza" Classes="primary" Click="Analyze_Click" IsEnabled="{Binding CanAnalyzeProject}"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="280,5,*" x:Name="WorkspaceGrid" ClipToBounds="True">
      <Border x:Name="SourcesPanel" Grid.Column="0" Background="#0A1019" Padding="14">
        <ScrollViewer><StackPanel Spacing="13">
          <StackPanel><TextBlock Text="PROGETTO" Classes="eyebrow"/><TextBlock Text="Sorgenti" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="FITS e XISF da qualsiasi software." Classes="muted" FontSize="11"/></StackPanel>
          <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="6"><Button Content="+ Cartella" Click="AddSources_Click"/><Button Grid.Column="1" Content="+ File" Click="AddFiles_Click"/><Button Grid.Column="2" Content="−" Click="RemoveSource_Click"/></Grid>
          <ListBox x:Name="SourcesList" ItemsSource="{Binding SourcePaths}" MaxHeight="180">
            <ListBox.ItemTemplate><DataTemplate><Border Classes="pathCard" Margin="0,0,0,5"><TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding}"/></Border></DataTemplate></ListBox.ItemTemplate>
          </ListBox>
          <Border Height="1" Background="#243146"/>
          <StackPanel><TextBlock Text="LIBRERIE DI CALIBRAZIONE" Classes="eyebrow"/><TextBlock Text="Indipendenti dal progetto" Classes="muted" FontSize="11"/></StackPanel>
          <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="5"><Button Content="+ Libreria" Click="AddLibrary_Click"/><Button Grid.Column="1" Content="↑" Click="MoveLibraryUp_Click"/><Button Grid.Column="2" Content="↓" Click="MoveLibraryDown_Click"/><Button Grid.Column="3" Content="−" Click="RemoveLibrary_Click"/></Grid>
          <ListBox ItemsSource="{Binding MasterLibraries}" SelectedItem="{Binding SelectedMasterLibrary}" MaxHeight="170">
            <ListBox.ItemTemplate><DataTemplate><Border Classes="pathCard" Margin="0,0,0,5"><Grid ColumnDefinitions="Auto,*,Auto"><CheckBox IsChecked="{Binding Enabled}"/><StackPanel Grid.Column="1" Margin="7,0"><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding Path}" Classes="muted" FontSize="10" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Path}"/></StackPanel><TextBlock Grid.Column="2" Text="{Binding Status}" Foreground="#49D9CA"/></Grid></Border></DataTemplate></ListBox.ItemTemplate>
          </ListBox>
          <Button Content="Aggiorna stato librerie" Click="RefreshLibraries_Click"/>
          <Border Classes="card"><StackPanel Spacing="8"><TextBlock Text="VALORI PREDEFINITI" Classes="eyebrow"/><TextBlock Text="Fallback solo quando header e percorso non bastano." Classes="muted" FontSize="10"/>
            <Grid ColumnDefinitions="*,88" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6"><TextBlock Text="Gain"/><TextBox Grid.Column="1" Text="{Binding ProjectDefaultGain}"/><TextBlock Grid.Row="1" Text="Offset"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ProjectDefaultOffset}"/><TextBlock Grid.Row="2" Text="Setpoint °C"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ProjectDefaultTemperature}"/><TextBlock Grid.Row="3" Text="Cambio notte"/><NumericUpDown Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="23" Value="{Binding SessionBoundaryHour}"/></Grid>
            <Button Content="Applica fallback e rianalizza" Command="{Binding ApplyProjectDefaultsCommand}"/>
          </StackPanel></Border>
        </StackPanel></ScrollViewer>
      </Border>
      <GridSplitter Grid.Column="1" Width="5" Background="#172233" ResizeDirection="Columns"/>

      <Grid Grid.Column="2" RowDefinitions="Auto,Auto,*" Margin="16,14">
        <Border Classes="health" Padding="14" Margin="0,0,0,10"><Grid ColumnDefinitions="*,Auto"><StackPanel><TextBlock Text="PROJECT HEALTH" Classes="eyebrow"/><TextBlock Text="{Binding ReadinessText}" Margin="0,3,0,0"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center"><TextBlock Text="{Binding Status}" Classes="muted"/><ProgressBar Width="150" Maximum="100" Value="{Binding Progress}"/></StackPanel></Grid></Border>
        <Border Grid.Row="1" Classes="warningBanner" IsVisible="{Binding HasRecoverySnapshot}" Margin="0,0,0,10"><Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="7"><StackPanel><TextBlock Text="RECUPERO DISPONIBILE" Classes="eyebrow"/><TextBlock Text="{Binding RecoverySummary}" TextWrapping="Wrap"/></StackPanel><Button Grid.Column="1" Content="Ripristina" Click="RestoreRecovery_Click"/><Button Grid.Column="2" Content="Ignora" Click="DiscardRecovery_Click"/></Grid></Border>
        <TabControl Grid.Row="2" x:Name="WorkspaceTabs">
          <TabItem Header="Analisi">
            <Grid x:Name="AnalysisGrid" Margin="0,12,0,0" ColumnDefinitions="*,0,0">
              <Border Classes="card" Padding="10"><Grid RowDefinitions="Auto,*">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"><TextBox PlaceholderText="Cerca file, filtro, sessione…" Text="{Binding SearchText}"/><CheckBox Grid.Column="1" Content="Solo da rivedere" IsChecked="{Binding ShowIssuesOnly}" VerticalAlignment="Center"/><Button Grid.Column="2" Content="Pulisci filtri" Click="ClearAnalysisFilters_Click"/></Grid>
                <TreeView Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding TreeRoots}" SelectedItem="{Binding SelectedNode}" DoubleTapped="Tree_DoubleTapped">
                  <TreeView.ItemTemplate><TreeDataTemplate ItemsSource="{Binding Children}"><Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="2,3"><CheckBox IsVisible="{Binding CanBeMarked}" IsChecked="{Binding IsMarked}" Click="TreeMark_Click"/><TextBlock Grid.Column="1" Text="{Binding Icon}" Foreground="#49D9CA" Margin="6,0"/><TextBlock Grid.Column="2" Text="{Binding Name}" FontWeight="SemiBold"/><Border Grid.Column="3" Classes="count"><TextBlock Text="{Binding Count}"/></Border><Border Grid.Column="4" Classes="warning" IsVisible="{Binding HasIssues}"><TextBlock Text="{Binding IssueCount}"/></Border></Grid></TreeDataTemplate></TreeView.ItemTemplate>
                </TreeView>
              </Grid></Border>
              <GridSplitter Grid.Column="1" Width="5" Background="#223247" ResizeDirection="Columns" IsVisible="{Binding HasSelection}"/>
              <Border Grid.Column="2" Classes="card" Padding="16" IsVisible="{Binding HasSelection}" Margin="8,0,0,0"><ScrollViewer><StackPanel Spacing="10">
                <TextBlock Text="INSPECTOR / OVERRIDE" Classes="eyebrow"/><TextBlock Text="{Binding SelectionTitle}" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="{Binding SelectionDetail}" Classes="muted"/>
                <TextBlock Text="Tipo frame" Classes="label"/><ComboBox ItemsSource="{Binding FrameKinds}" SelectedItem="{Binding EditKind}"/>
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="7"><TextBlock Text="Gain"/><TextBlock Grid.Column="1" Text="{Binding GainSource}" Classes="source"/><TextBox Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding EditGain}"/><TextBlock Grid.Row="2" Text="Offset"/><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding OffsetSource}" Classes="source"/><TextBox Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding EditOffset}"/><TextBlock Grid.Row="4" Text="Temperatura (°C)"/><TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding TemperatureSource}" Classes="source"/><TextBox Grid.Row="5" Grid.ColumnSpan="2" Text="{Binding EditTemperature}"/></Grid>
                <TextBlock Text="Filtro" Classes="label"/><TextBox Text="{Binding EditFilter}"/>
                <TextBlock Text="Flat Epoch / Set" Classes="label"/><TextBox Text="{Binding EditFlatSet}"/>
                <TextBlock Text="Sessione astronomica" Classes="label"/><TextBox Text="{Binding EditSession}"/>
                <Button Content="{Binding ApplyLabel}" Classes="primary" Command="{Binding ApplyOverridesCommand}"/>
                <Border Height="1" Background="#27364A"/>
                <TextBlock Text="LINK MANUALE FLAT EPOCH" Classes="eyebrow"/><TextBlock Text="{Binding ManualLinkSelectionText}" Classes="muted" TextWrapping="Wrap"/><ComboBox ItemsSource="{Binding AvailableFlatSets}" SelectedItem="{Binding SelectedFlatSet}"/><Grid ColumnDefinitions="*,*" ColumnSpacing="8"><Button Content="Collega" Command="{Binding LinkFlatSetCommand}"/><Button Grid.Column="1" Content="Torna automatico" Command="{Binding UnlinkFlatSetCommand}"/></Grid>
                <Expander Header="Header effettivi"><TextBox Text="{Binding RawHeaders}" IsReadOnly="True" AcceptsReturn="True" MinHeight="160" FontFamily="Consolas"/></Expander>
              </StackPanel></ScrollViewer></Border>
            </Grid>
          </TabItem>

          <TabItem Header="Struttura"><Grid Margin="0,12,0,0" RowDefinitions="*,Auto,Auto">
            <Border Classes="card" Padding="10"><TreeView ItemsSource="{Binding PlannedTreeRoots}"><TreeView.ItemTemplate><TreeDataTemplate ItemsSource="{Binding Children}"><Grid ColumnDefinitions="Auto,*,Auto" Margin="3"><TextBlock Text="{Binding Icon}" Foreground="#49D9CA" Margin="4"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding Detail}" Classes="muted" FontSize="10"/></StackPanel><Border Grid.Column="2" Classes="count"><TextBlock Text="{Binding Count}"/></Border></Grid></TreeDataTemplate></TreeView.ItemTemplate></TreeView></Border>
            <Border Grid.Row="1" Classes="card" Margin="0,10,0,0"><Grid ColumnDefinitions="220,*,Auto,Auto" ColumnSpacing="8"><TextBox PlaceholderText="Nome progetto" Text="{Binding ProjectName}"/><TextBox Grid.Column="1" PlaceholderText="Cartella destinazione" Text="{Binding DestinationPath}"/><Button Grid.Column="2" Content="Scegli…" Click="ChooseDestination_Click"/><Button Grid.Column="3" Content="Genera piano" Click="BuildPlan_Click"/></Grid></Border>
            <Border Grid.Row="2" Classes="card" Margin="0,10,0,0"><Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="8"><StackPanel><TextBlock Text="EXPORT VERIFICATO" Classes="eyebrow"/><TextBlock Text="{Binding PlanSummary}" Classes="muted" TextWrapping="Wrap"/><TextBlock Text="{Binding ExportProgressDetail}" TextWrapping="Wrap"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"><Button Content="Preflight" Click="ExportPreflight_Click" IsEnabled="{Binding CanRunExportPreflight}"/><Button Content="Esporta" Classes="primary" Click="Export_Click" IsEnabled="{Binding CanStartExport}"/><Button Content="Pausa" Click="PauseExport_Click" IsEnabled="{Binding CanPauseExport}"/><Button Content="Riprendi" Click="ResumeExport_Click" IsEnabled="{Binding CanResumeExport}"/><Button Content="Annulla" Click="CancelExport_Click" IsEnabled="{Binding CanCancelExport}"/></StackPanel><ItemsControl Grid.Row="1" Grid.ColumnSpan="2" ItemsSource="{Binding ExportPreflightFindings}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border Classes="note" Margin="0,3,6,0"><TextBlock Text="{Binding Title}" ToolTip.Tip="{Binding Detail}"/></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></Grid></Border>
          </Grid></TabItem>

          <TabItem Header="WBPP"><ScrollViewer><StackPanel Margin="0,12,0,0" Spacing="10"><TextBlock Text="Grouping Keywords consigliate" Classes="title"/><TextBlock Text="Calcolate dalle sessioni reali e dai Flat Epoch assegnati." Classes="muted"/><ItemsControl ItemsSource="{Binding WbppKeywords}"><ItemsControl.ItemTemplate><DataTemplate><Border Classes="card" Margin="0,0,0,7"><Grid ColumnDefinitions="150,80,80,*"><TextBlock Text="{Binding Keyword}" Foreground="#49D9CA" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="{Binding Pre}"/><TextBlock Grid.Column="2" Text="{Binding Post}"/><TextBlock Grid.Column="3" Text="{Binding Reason}" TextWrapping="Wrap"/></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><ItemsControl ItemsSource="{Binding WbppNotes}"><ItemsControl.ItemTemplate><DataTemplate><Border Classes="note" Margin="0,0,0,6"><TextBlock Text="{Binding}" TextWrapping="Wrap"/></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></ScrollViewer></TabItem>

          <TabItem Header="Dati"><ScrollViewer><StackPanel Margin="0,12,0,0" Spacing="12"><Grid ColumnDefinitions="*,*,*" ColumnSpacing="10"><Border Classes="metric"><StackPanel><TextBlock Text="INTEGRAZIONE TOTALE" Classes="eyebrow"/><TextBlock Text="{Binding TotalIntegrationText}" Classes="metricValue"/></StackPanel></Border><Border Grid.Column="1" Classes="metric"><StackPanel><TextBlock Text="COPERTURA" Classes="eyebrow"/><TextBlock Text="{Binding StatisticsSummary}" TextWrapping="Wrap" Margin="0,8,0,0"/></StackPanel></Border><Border Grid.Column="2" Classes="metric"><StackPanel><TextBlock Text="INTERVALLO" Classes="eyebrow"/><TextBlock Text="{Binding StatisticsDateRange}" Margin="0,8,0,0"/></StackPanel></Border></Grid><Button Content="Esporta dati CSV + JSON" HorizontalAlignment="Right" Click="ExportStatistics_Click"/><TextBlock Text="PER FILTRO" Classes="eyebrow"/><ItemsControl ItemsSource="{Binding FilterStatistics}"><ItemsControl.ItemTemplate><DataTemplate><Border Classes="card" Margin="0,0,0,8"><Grid ColumnDefinitions="180,180,150,*,Auto"><StackPanel><TextBlock Text="{Binding Filter}" FontSize="20" FontWeight="SemiBold"/><TextBlock Text="{Binding Gain, StringFormat=Gain: {0}}" Classes="muted"/><TextBlock Text="{Binding Temperature, StringFormat=Temperatura: {0}}" Classes="muted"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="{Binding Integration}" FontSize="20" Foreground="#49D9CA"/><TextBlock Text="{Binding Lights, StringFormat={}{0} Light}" Classes="muted"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="{Binding NightsLabel}"/><TextBlock Text="{Binding SessionsLabel}" Classes="muted"/></StackPanel><TextBlock Grid.Column="3" Text="{Binding Calibration}" TextWrapping="Wrap"/><TextBlock Grid.Column="4" Text="{Binding Status}" Foreground="#49D9CA"/></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><TextBlock Text="SESSIONI DI CONFIGURAZIONE" Classes="eyebrow"/><ItemsControl ItemsSource="{Binding SessionStatistics}"><ItemsControl.ItemTemplate><DataTemplate><Border Classes="card" Margin="0,0,0,8"><Grid ColumnDefinitions="120,*,150,120,Auto"><TextBlock Text="{Binding Filter}" Foreground="#49D9CA"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding Session}"/><TextBlock Text="{Binding TechnicalId}" Classes="muted"/></StackPanel><TextBlock Grid.Column="2" Text="{Binding Integration}"/><TextBlock Grid.Column="3" Text="{Binding NightsLabel}"/><TextBlock Grid.Column="4" Text="{Binding Status}"/></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></ScrollViewer></TabItem>

          <TabItem Header="Quality"><Grid Margin="0,12,0,0" RowDefinitions="Auto,220,*" RowSpacing="9">
            <Border Classes="card" Padding="10"><Grid ColumnDefinitions="280,*,410" ColumnSpacing="8"><StackPanel><TextBlock Text="SERIE DI CALIBRAZIONE" Classes="eyebrow"/><ComboBox ItemsSource="{Binding QualitySeries}" SelectedItem="{Binding SelectedQualitySeries}" DisplayMemberBinding="{Binding Display}" SelectionChanged="QualitySeries_SelectionChanged"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="SOGLIA DI SCARTO" Classes="eyebrow"/><Slider Minimum="1" Maximum="8" Value="{Binding QualitySigmaThreshold}" TickFrequency="0.1" PropertyChanged="QualityThreshold_Changed"/><Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding QualityTableSummary}" Classes="muted"/><CheckBox Grid.Column="1" Content="Solo sospetti" IsChecked="{Binding QualityShowOnlySuspects}"/></Grid></StackPanel><WrapPanel Grid.Column="2"><Button Content="Analizza" Classes="primary" Click="AnalyzeQuality_Click" IsEnabled="{Binding CanRunQualityAnalysis}"/><Button Content="Annulla" Click="CancelQuality_Click" IsEnabled="{Binding IsQualityAnalyzing}"/><Button Content="Escludi selezione" Click="ExcludeSelectedQuality_Click" IsEnabled="{Binding CanExcludeSelectedQuality}"/><Button Content="Escludi sospetti" Click="ExcludeQualitySuspects_Click" IsEnabled="{Binding CanExcludeQualitySuspects}"/><Button Content="Ripristina" Click="RestoreQuality_Click"/></WrapPanel></Grid></Border>
            <Border Grid.Row="1" Classes="chartCard"><local:QualityDistributionChart x:Name="QualityChart" Items="{Binding QualityChartFrames}" Threshold="{Binding QualitySigmaThreshold}" SelectedItem="{Binding SelectedQualityFrame}" PointerPressed="QualityChart_PointerPressed"/></Border>
            <Grid Grid.Row="2" ColumnDefinitions="1.1*,1.4*" ColumnSpacing="9"><DataGrid x:Name="QualityGrid" ItemsSource="{Binding QualityFrames}" SelectedItem="{Binding SelectedQualityFrame}" SelectionMode="Extended" IsReadOnly="True" AutoGenerateColumns="False" SelectionChanged="QualityGrid_SelectionChanged" DoubleTapped="QualityGrid_DoubleTapped"><DataGrid.Columns><DataGridTextColumn Header="Stato" Binding="{Binding State}" SortMemberPath="State" Width="90"/><DataGridTextColumn Header="File" Binding="{Binding FileName}" SortMemberPath="FileName" Width="*"/><DataGridTextColumn Header="FWHM" Binding="{Binding FwhmText}" SortMemberPath="Fwhm" Width="70"/><DataGridTextColumn Header="Ecc." Binding="{Binding EccentricityText}" SortMemberPath="Eccentricity" Width="70"/><DataGridTextColumn Header="Rumore" Binding="{Binding NoiseText}" SortMemberPath="Noise" Width="75"/><DataGridTextColumn Header="SNR" Binding="{Binding SnrText}" SortMemberPath="Snr" Width="65"/><DataGridTextColumn Header="Stelle" Binding="{Binding StarsText}" SortMemberPath="StarCount" Width="70"/><DataGridTextColumn Header="Score" Binding="{Binding OutlierScore}" SortMemberPath="OutlierScore" Width="70"/></DataGrid.Columns></DataGrid>
              <Border Grid.Column="1" Classes="preview"><Grid RowDefinitions="Auto,Auto,*"><Grid ColumnDefinitions="*,Auto"><StackPanel><TextBlock Text="BLINK / ISPEZIONE" Classes="eyebrow"/><TextBlock Text="{Binding SelectedQualityFrame.FileName}" TextTrimming="CharacterEllipsis"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5"><Button x:Name="BlinkButton" Content="Avvia Blink" Click="Blink_Click"/><Button Content="Escludi / ripristina" Click="ToggleQualityExclusion_Click"/><Button Content="Dettaglio HD" Click="QualityFullResolution_Click"/><Button Content="−" Click="ZoomOut_Click"/><Button Content="Adatta" Click="ZoomFit_Click"/><Button Content="+" Click="ZoomIn_Click"/></StackPanel></Grid><Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*" Margin="0,6"><CheckBox Content="Debayer temporaneo" IsChecked="{Binding QualityDebayerPreview}" Click="QualityPreviewOptions_Click"/><TextBlock Grid.Column="1" Text="Stretch" Classes="muted" Margin="14,0,6,0"/><Slider Grid.Column="2" Minimum="0" Maximum="12" Value="{Binding QualityStretchStrength}" PropertyChanged="QualityStretch_Changed"/></Grid><ScrollViewer Grid.Row="2" x:Name="QualityPreviewScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"><Image x:Name="QualityPreviewImage" Source="{Binding SelectedQualityFrame.Preview}" Stretch="None" RenderTransformOrigin="0,0"><Image.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Image.RenderTransform></Image></ScrollViewer></Grid></Border></Grid>
          </Grid></TabItem>

          <TabItem Header="Revisione"><Grid Margin="0,12,0,0" ColumnDefinitions="1.1*,1*" ColumnSpacing="10"><ListBox ItemsSource="{Binding ReviewQueue}" SelectionChanged="ReviewQueue_SelectionChanged" DoubleTapped="ReviewQueue_DoubleTapped"><ListBox.ItemTemplate><DataTemplate><Border Classes="card" Margin="0,0,0,7"><Grid ColumnDefinitions="90,*,Auto"><TextBlock Text="{Binding Calibration}" Foreground="#FFAF62"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding Frame.FileName}" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding Reason}" Classes="muted" TextWrapping="Wrap"/></StackPanel><TextBlock Grid.Column="2" Text="{Binding CandidateLabel}"/></Grid></Border></DataTemplate></ListBox.ItemTemplate></ListBox><Border Grid.Column="1" Classes="card"><StackPanel Spacing="10"><TextBlock Text="ASSEGNAZIONE GUIDATA" Classes="eyebrow"/><TextBlock Text="Seleziona un problema e scegli il Master compatibile." Classes="muted"/><ItemsControl ItemsSource="{Binding ReviewQueue}"><ItemsControl.ItemTemplate><DataTemplate><Border IsVisible="{Binding CanAssignMaster}" Classes="note" Margin="0,0,0,7"><StackPanel Spacing="6"><TextBlock Text="{Binding TargetSignature}" TextWrapping="Wrap"/><ComboBox ItemsSource="{Binding Candidates}" SelectedItem="{Binding SelectedCandidate}" DisplayMemberBinding="{Binding Display}"/><Grid ColumnDefinitions="*,*,*" ColumnSpacing="6"><Button Content="Solo Light" Click="AssignLight_Click"/><Button Grid.Column="1" Content="Intera notte" Click="AssignNight_Click"/><Button Grid.Column="2" Content="Sessione" Click="AssignSession_Click"/></Grid></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border></Grid></TabItem>

          <TabItem Header="Master Lab"><Grid Margin="0,12,0,0" RowDefinitions="Auto,*" RowSpacing="10"><Border Classes="card"><Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8"><StackPanel><TextBlock Text="MASTER LIBRARY LAB" Classes="title"/><TextBlock Text="Scansiona, completa i metadati mancanti e crea una libreria normalizzata. Non richiede un progetto." Classes="muted"/></StackPanel><Button Grid.Column="1" Content="Scansiona librerie" Click="ScanMasterLibraries_Click"/><Button Grid.Column="2" Content="Preflight" Click="PreviewMasterOrganizer_Click"/><Button Grid.Column="3" Content="Rollback" Click="RollbackMasterOrganizer_Click"/></Grid></Border><Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="8"><Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"><TextBox Text="{Binding MasterOrganizerDestination}" PlaceholderText="Destinazione nuova libreria"/><Button Grid.Column="1" Content="Scegli destinazione" Click="ChooseMasterOrganizerDestination_Click"/><Button Grid.Column="2" Content="Copia, imprimi e organizza" Classes="primary" Click="OrganizeMasterLibrary_Click"/></Grid><DataGrid Grid.Row="1" ItemsSource="{Binding MasterOrganizerItems}" AutoGenerateColumns="False" DoubleTapped="MasterOrganizer_DoubleTapped"><DataGrid.Columns><DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="2*"/><DataGridTextColumn Header="Tipo" Binding="{Binding Kind}" Width="80"/><DataGridTextColumn Header="Camera" Binding="{Binding Camera, Mode=TwoWay}" Width="140"/><DataGridTextColumn Header="Gain" Binding="{Binding Gain, Mode=TwoWay}" Width="80"/><DataGridTextColumn Header="Offset" Binding="{Binding Offset, Mode=TwoWay}" Width="80"/><DataGridTextColumn Header="Temperatura" Binding="{Binding Temperature, Mode=TwoWay}" Width="100"/><DataGridTextColumn Header="Esposizione" Binding="{Binding Exposure, Mode=TwoWay}" Width="100"/><DataGridTextColumn Header="Readout" Binding="{Binding ReadoutMode, Mode=TwoWay}" Width="110"/><DataGridTextColumn Header="Destinazione" Binding="{Binding SuggestedPath}" Width="2*"/><DataGridTextColumn Header="Stato" Binding="{Binding State}" Width="150"/></DataGrid.Columns></DataGrid></Grid></Grid></TabItem>
          <TabItem Header="Log"><Grid Margin="0,12,0,0" RowDefinitions="Auto,*" RowSpacing="10"><Border Classes="card"><Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"><StackPanel><TextBlock Text="CENTRO DIAGNOSTICA" Classes="title"/><TextBlock Text="{Binding DiagnosticsSummary}" Classes="muted"/><TextBlock Text="Log locali e redatti: niente pixel, target, coordinate o percorsi completi." Classes="muted"/></StackPanel><Button Grid.Column="1" Content="Aggiorna" Click="RefreshDiagnostics_Click"/><Button Grid.Column="2" Content="Esporta support ZIP" Click="ExportSupport_Click"/></Grid></Border><DataGrid Grid.Row="1" ItemsSource="{Binding DiagnosticEvents}" AutoGenerateColumns="False" IsReadOnly="True"><DataGrid.Columns><DataGridTextColumn Header="Ora" Binding="{Binding Timestamp}" Width="150"/><DataGridTextColumn Header="Livello" Binding="{Binding Level}" Width="80"/><DataGridTextColumn Header="Codice" Binding="{Binding Code}" Width="150"/><DataGridTextColumn Header="Operazione" Binding="{Binding Operation}" Width="180"/><DataGridTextColumn Header="ID" Binding="{Binding Correlation}" Width="90"/><DataGridTextColumn Header="Messaggio" Binding="{Binding Message}" Width="*"/></DataGrid.Columns></DataGrid></Grid></TabItem>
        </TabControl>
      </Grid>
    </Grid>

    <Border Grid.Row="1" x:Name="SettingsPanel" IsVisible="False" HorizontalAlignment="Right" Width="390" Background="#101927" BorderBrush="#33445C" BorderThickness="1,0,0,0" Padding="20" ZIndex="20"><ScrollViewer><StackPanel Spacing="12"><Grid ColumnDefinitions="*,Auto"><TextBlock Text="Impostazioni" Classes="title"/><Button Grid.Column="1" Content="✕" Click="ToggleSettings_Click"/></Grid><TextBlock Text="INTERFACCIA" Classes="eyebrow"/><ComboBox SelectedItem="{Binding UiDensity}"><ComboBoxItem Content="Comoda"/><ComboBoxItem Content="Compatta"/></ComboBox><CheckBox Content="Movimento ridotto" IsChecked="{Binding ReducedMotion}"/><TextBlock Text="ESPORTAZIONE" Classes="eyebrow"/><TextBlock Text="Margine spazio (%)"/><NumericUpDown Value="{Binding ExportMarginPercent}" Minimum="0" Maximum="100"/><TextBlock Text="Riserva minima (GiB)"/><NumericUpDown Value="{Binding ExportMinimumReserveGiB}" Minimum="0" Maximum="1000"/><Button Content="Salva impostazioni" Classes="primary" Command="{Binding SaveSettingsCommand}"/><Button Content="Riapri guida iniziale" Click="OpenOnboarding_Click"/><Button Content="Pulisci cache header" Click="ClearCache_Click"/><Button Content="Esporta diagnostica" Click="ExportSupport_Click"/><Button Content="Svuota progetto" Command="{Binding ClearProjectCommand}"/></StackPanel></ScrollViewer></Border>
    <Border Grid.RowSpan="2" IsVisible="{Binding ShowOnboarding}" Background="#D9080C13" ZIndex="40">
      <Border Classes="card" Width="680" MaxHeight="610" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30"><StackPanel Spacing="16"><TextBlock Text="BENVENUTO IN ASTROPROJECT FORGE" Classes="eyebrow"/><TextBlock Text="Dagli header al progetto WBPP, senza ipotesi nascoste" FontSize="30" FontWeight="SemiBold" TextWrapping="Wrap"/><TextBlock Text="Puoi iniziare dai Light/Flat oppure preparare soltanto la Master Library: i due flussi sono indipendenti. FITS e XISF possono provenire da qualunque software; gli originali restano sempre in sola lettura." Classes="muted" TextWrapping="Wrap"/><Grid ColumnDefinitions="*,*" ColumnSpacing="10"><Border Classes="note"><StackPanel Spacing="8"><TextBlock Text="1 · PROGETTO" Classes="eyebrow"/><TextBlock Text="Collega file o cartelle. L’analisi ricostruisce notte astronomica, filtro e sessione ottica." TextWrapping="Wrap"/><Grid ColumnDefinitions="*,*" ColumnSpacing="6"><Button Content="Aggiungi cartelle" Click="AddSources_Click"/><Button Grid.Column="1" Content="Aggiungi file" Click="AddFiles_Click"/></Grid></StackPanel></Border><Border Grid.Column="1" Classes="note"><StackPanel Spacing="8"><TextBlock Text="2 · MASTER LIBRARY" Classes="eyebrow"/><TextBlock Text="Aggiungi una o più librerie. Master Library Lab funziona anche senza progetto." TextWrapping="Wrap"/><Button Content="Aggiungi libreria" Click="AddLibrary_Click"/></StackPanel></Border></Grid><TextBlock Text="Gain 100 e Offset 51 sono fallback iniziali modificabili: un header valido ha sempre precedenza." Classes="muted" TextWrapping="Wrap"/><Grid ColumnDefinitions="*,Auto"><TextBlock Text="Nessun dato viene caricato online." Classes="muted" VerticalAlignment="Center"/><Button Grid.Column="1" Content="Entra nel workspace" Classes="primary" Click="CompleteOnboarding_Click"/></Grid></StackPanel></Border>
    </Border>
  </Grid>
</Window>
