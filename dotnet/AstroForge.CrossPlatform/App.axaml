<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AstroForge.CrossPlatform.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
    <Style Selector="Window"><Setter Property="Background" Value="#080C13"/><Setter Property="FontFamily" Value="Inter"/></Style>
    <Style Selector="Button"><Setter Property="CornerRadius" Value="9"/><Setter Property="Padding" Value="12,8"/><Setter Property="FontSize" Value="12"/></Style>
    <Style Selector="TabItem"><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="12,8"/><Setter Property="MinWidth" Value="0"/></Style>
    <Style Selector="Button.primary"><Setter Property="Background" Value="#42D5C6"/><Setter Property="Foreground" Value="#06110F"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
    <Style Selector="Border.card"><Setter Property="Background" Value="#111A27"/><Setter Property="BorderBrush" Value="#27364A"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="14"/><Setter Property="Padding" Value="18"/></Style>
    <Style Selector="Border.health"><Setter Property="Background" Value="#0E2626"/><Setter Property="BorderBrush" Value="#225B56"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="13"/></Style>
    <Style Selector="Border.warningBanner"><Setter Property="Background" Value="#34230F"/><Setter Property="BorderBrush" Value="#8C5A20"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="12"/><Setter Property="Padding" Value="12"/></Style>
    <Style Selector="Border.pathCard"><Setter Property="Background" Value="#111A27"/><Setter Property="BorderBrush" Value="#27364A"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="9"/><Setter Property="Padding" Value="9"/></Style>
    <Style Selector="Border.note"><Setter Property="Background" Value="#0E1C29"/><Setter Property="BorderBrush" Value="#203A50"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="10"/><Setter Property="Padding" Value="12"/></Style>
    <Style Selector="Border.metric"><Setter Property="Background" Value="#111A27"/><Setter Property="BorderBrush" Value="#2B3C52"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="14"/><Setter Property="Padding" Value="18"/></Style>
    <Style Selector="Border.chartCard"><Setter Property="Background" Value="#0B121C"/><Setter Property="BorderBrush" Value="#27364A"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="12"/><Setter Property="Padding" Value="12"/></Style>
    <Style Selector="Border.preview"><Setter Property="Background" Value="#030609"/><Setter Property="BorderBrush" Value="#27364A"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="12"/><Setter Property="Padding" Value="10"/></Style>
    <Style Selector="Border.count"><Setter Property="Background" Value="#1B2636"/><Setter Property="CornerRadius" Value="9"/><Setter Property="Padding" Value="7,2"/><Setter Property="Margin" Value="5,0"/></Style>
    <Style Selector="Border.warning"><Setter Property="Background" Value="#603714"/><Setter Property="CornerRadius" Value="9"/><Setter Property="Padding" Value="7,2"/><Setter Property="Margin" Value="2,0"/></Style>
    <Style Selector="TextBlock.eyebrow"><Setter Property="Foreground" Value="#42D5C6"/><Setter Property="FontSize" Value="11"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
    <Style Selector="TextBlock.muted"><Setter Property="Foreground" Value="#91A4BD"/></Style>
    <Style Selector="TextBlock.title"><Setter Property="FontSize" Value="28"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
    <Style Selector="TextBlock.metricValue"><Setter Property="FontSize" Value="31"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Margin" Value="0,8,0,0"/></Style>
    <Style Selector="TextBlock.label"><Setter Property="Foreground" Value="#AEC0D5"/><Setter Property="Margin" Value="0,4,0,0"/></Style>
    <Style Selector="TextBlock.source"><Setter Property="Foreground" Value="#49D9CA"/><Setter Property="FontSize" Value="10"/></Style>
    <Style Selector="TextBox"><Setter Property="Background" Value="#0B121D"/><Setter Property="BorderBrush" Value="#2A3A4F"/></Style>
    <Style Selector="ListBox"><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/></Style>
  </Application.Styles>
</Application>
