<Window x:Class="AstroForge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AstroForge.App.ViewModels"
        xmlns:controls="clr-namespace:AstroForge.App.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="AstroProject Forge" Width="1540" Height="940" MinWidth="900" MinHeight="650"
        WindowStartupLocation="CenterScreen" Icon="Assets/astroforge.ico" SizeChanged="Window_SizeChanged"
        WindowStyle="None" ResizeMode="CanResize" Background="#080A0F">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42" ResizeBorderThickness="7" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource GlassSurface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="13" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="MetaLabel" TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="SourceBadge" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <HierarchicalDataTemplate DataType="{x:Type vm:ProjectTreeNode}" ItemsSource="{Binding Children}">
            <Border x:Name="NodeBorder" Padding="7,5" CornerRadius="7" Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" IsChecked="{Binding IsMarked, Mode=TwoWay}" Visibility="{Binding CanBeMarked, Converter={StaticResource BooleanToVisibility}}" Checked="TreeMark_Changed" Unchecked="TreeMark_Changed" ToolTip="Marca questo gruppo per il link manuale Flat"/>
                    <Border Grid.Column="1" Width="22" Height="22" CornerRadius="6" Background="#172A32" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Icon}" Foreground="{StaticResource Accent}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
                    </Border>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" FontWeight="Medium" />
                        <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedText}" FontSize="10" TextTrimming="CharacterEllipsis" Visibility="{Binding IsLeaf, Converter={StaticResource BooleanToVisibility}}" />
                    </StackPanel>
                    <Border Grid.Column="3" Background="#172130" CornerRadius="9" Padding="7,2" Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Count}" Foreground="{StaticResource Muted}" FontSize="11" />
                    </Border>
                    <Border Grid.Column="4" Background="#4A2C20" CornerRadius="9" Padding="7,2" Margin="5,0,0,0" VerticalAlignment="Center" Visibility="{Binding HasIssues, Converter={StaticResource BooleanToVisibility}}">
                        <TextBlock Text="{Binding IssueCount}" Foreground="{StaticResource Warning}" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                </Grid>
            </Border>
            <HierarchicalDataTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="NodeBorder" Property="Background" Value="#941B3040"/></Trigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid x:Name="RootSurface" Background="{StaticResource AppBackground}" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform><TranslateTransform Y="0"/></Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Ellipse Grid.RowSpan="3" Width="820" Height="820" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-520,-580,0,0" Opacity="0.52" IsHitTestVisible="False"><Ellipse.Fill><RadialGradientBrush><GradientStop Color="#312ABCB3" Offset="0"/><GradientStop Color="#002ABCB3" Offset="1"/></RadialGradientBrush></Ellipse.Fill></Ellipse>
        <Ellipse Grid.RowSpan="3" Width="760" Height="760" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-500,-520" Opacity="0.45" IsHitTestVisible="False"><Ellipse.Fill><RadialGradientBrush><GradientStop Color="#2C617CD9" Offset="0"/><GradientStop Color="#00617CD9" Offset="1"/></RadialGradientBrush></Ellipse.Fill></Ellipse>

        <Border Grid.Row="0" Background="#F20B0E14" BorderBrush="#263142" BorderThickness="0,0,0,1">
            <Grid Margin="18,0,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="138"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="38" Height="38" CornerRadius="11" Background="#171F2A" BorderBrush="#3A4A5F" BorderThickness="1" Margin="0,0,12,0">
                        <Image Source="Assets/astroforge.ico" Width="24" Height="24" Stretch="Uniform"/>
                    </Border>
                    <StackPanel x:Name="BrandText" VerticalAlignment="Center">
                        <TextBlock Text="ASTROPROJECT FORGE" FontFamily="Segoe UI Variable Display" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="PREPARAZIONE WBPP" Foreground="{StaticResource Subtle}" FontWeight="SemiBold" FontSize="9" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Border x:Name="ProjectStatusBadge" Height="38" MinWidth="112" MaxWidth="155" Background="#B8121720" BorderBrush="{StaticResource Stroke}" BorderThickness="1" CornerRadius="8" Padding="11,0" Margin="0,0,7,0" ToolTip="{Binding CurrentProjectFile}"><TextBlock Text="{Binding ProjectDocumentStatus}" Style="{StaticResource MutedText}" FontSize="10" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Center"/></Border>
                    <Button x:Name="SourceToggleButton" Content="Sorgenti" Click="ToggleSources_Click" Style="{StaticResource ToolbarButton}" ToolTip="Mostra o nasconde sorgenti e librerie"/>
                    <Button x:Name="InspectorToggleButton" Content="Inspector" Click="ToggleInspector_Click" Style="{StaticResource ToolbarButton}" ToolTip="Mostra o nasconde Inspector"/>
                    <Button x:Name="OpenProjectButton" Content="Apri" Click="OpenProject_Click" Style="{StaticResource ToolbarButton}" ToolTip="Apri un progetto .astroforge"/>
                    <Button x:Name="SaveProjectButton" Content="Salva" Click="SaveProject_Click" Style="{StaticResource ToolbarButton}" ToolTip="Salva il progetto .astroforge"/>
                    <Button x:Name="MoreButton" Content="•••" Click="More_Click" Style="{StaticResource ToolbarButton}" Width="44" Padding="0" ToolTip="Altri comandi" />
                    <Button x:Name="SettingsButton" Content="Impostazioni" Click="Settings_Click" Style="{StaticResource ToolbarButton}" Margin="0" ToolTip="Preferenze interfaccia" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="—" Click="MinimizeWindow_Click" Style="{StaticResource GhostButton}" Width="46" Height="42" Padding="0" FontSize="14" ToolTip="Riduci"/>
                    <Button Content="□" Click="MaximizeWindow_Click" Style="{StaticResource GhostButton}" Width="46" Height="42" Padding="0" FontSize="15" ToolTip="Ingrandisci o ripristina"/>
                    <Button Content="×" Click="CloseWindow_Click" Style="{StaticResource GhostButton}" Width="46" Height="42" Padding="0" FontSize="18" ToolTip="Chiudi"/>
                </StackPanel>
            </Grid>
        </Border>

        <Popup x:Name="MorePopup" Grid.Row="1" PlacementTarget="{Binding ElementName=MoreButton}" Placement="Bottom" HorizontalOffset="-260" VerticalOffset="8" StaysOpen="False" AllowsTransparency="True">
            <Border Width="310" Style="{StaticResource Card}" Background="#F2121B28" BorderBrush="#647A94" Padding="12">
                <StackPanel>
                    <TextBlock Text="Progetto" Style="{StaticResource Eyebrow}" Margin="8,5,8,10"/>
                    <Button Command="{Binding UndoCommand}" Click="CloseMore_Click" HorizontalContentAlignment="Stretch" Margin="0,0,0,6"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="↶" Foreground="{StaticResource Accent}" FontSize="18" VerticalAlignment="Center"/><StackPanel Grid.Column="1"><TextBlock Text="Annulla ultima modifica" FontWeight="SemiBold"/><TextBlock Text="Ripristina l'ultimo override" Style="{StaticResource MutedText}" FontSize="10"/></StackPanel></Grid></Button>
                    <Button Click="ClearCache_Click" HorizontalContentAlignment="Stretch" Margin="0,0,0,6"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="⌁" Foreground="{StaticResource Accent}" FontSize="18" VerticalAlignment="Center"/><StackPanel Grid.Column="1"><TextBlock Text="Pulisci cache header" FontWeight="SemiBold"/><TextBlock Text="Non elimina immagini" Style="{StaticResource MutedText}" FontSize="10"/></StackPanel></Grid></Button>
                    <Button Click="OpenDiagnostics_Click" HorizontalContentAlignment="Stretch" Margin="0,0,0,6"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="◎" Foreground="{StaticResource Accent}" FontSize="18" VerticalAlignment="Center"/><StackPanel Grid.Column="1"><TextBlock Text="Centro diagnostica" FontWeight="SemiBold"/><TextBlock Text="Eventi, errori e operazioni correlate" Style="{StaticResource MutedText}" FontSize="10"/></StackPanel></Grid></Button>
                    <Button Click="ShowAbout_Click" HorizontalContentAlignment="Stretch" Margin="0,0,0,6"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="i" Foreground="{StaticResource Accent}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/><StackPanel Grid.Column="1"><TextBlock Text="Informazioni e aggiornamenti" FontWeight="SemiBold"/><TextBlock Text="Versione, canale e integrità release" Style="{StaticResource MutedText}" FontSize="10"/></StackPanel></Grid></Button>
                    <Button Click="ExportSupportBundle_Click" HorizontalContentAlignment="Stretch" Margin="0,0,0,6"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="?" Foreground="{StaticResource Accent}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/><StackPanel Grid.Column="1"><TextBlock Text="Esporta diagnostica" FontWeight="SemiBold"/><TextBlock Text="ZIP locale senza immagini o percorsi" Style="{StaticResource MutedText}" FontSize="10"/></StackPanel></Grid></Button>
                    <Button Command="{Binding ClearProjectCommand}" Click="CloseMore_Click" HorizontalContentAlignment="Stretch" BorderBrush="#71434A"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="×" Foreground="{StaticResource Danger}" FontSize="20" VerticalAlignment="Center"/><StackPanel Grid.Column="1"><TextBlock Text="Svuota progetto" FontWeight="SemiBold"/><TextBlock Text="Scarica i dati, conserva gli originali" Style="{StaticResource MutedText}" FontSize="10"/></StackPanel></Grid></Button>
                </StackPanel>
            </Border>
        </Popup>

        <Popup x:Name="SettingsPopup" Grid.Row="1" PlacementTarget="{Binding ElementName=SettingsButton}" Placement="Bottom" HorizontalOffset="-300" VerticalOffset="8" StaysOpen="False" AllowsTransparency="True">
            <Border Width="380" Style="{StaticResource Card}" Background="#F2121B28" BorderBrush="#647A94" Padding="20">
                <StackPanel>
                    <TextBlock Text="Interfaccia" Style="{StaticResource Eyebrow}"/>
                    <TextBlock Text="Impostazioni" FontSize="22" FontWeight="SemiBold" Margin="0,5,0,15"/>
                    <TextBlock Text="Densità controlli" Style="{StaticResource MetaLabel}"/>
                    <ComboBox x:Name="DensitySelector" SelectedValuePath="Content" SelectedValue="{Binding UiDensity, Mode=TwoWay}" SelectionChanged="DensitySelector_SelectionChanged" Margin="0,0,0,13">
                        <ComboBoxItem Content="Compatta"/><ComboBoxItem Content="Comoda"/><ComboBoxItem Content="Ampia"/>
                    </ComboBox>
                    <CheckBox Content="Movimento ridotto" IsChecked="{Binding ReducedMotion, Mode=TwoWay}" Click="ReducedMotion_Click" Margin="0,3,0,7"/>
                    <TextBlock Text="Disattiva le animazioni dell’interfaccia." Style="{StaticResource MutedText}" TextWrapping="Wrap" FontSize="11"/>
                    <Border Height="1" Background="{StaticResource Stroke}" Margin="0,15,0,14"/>
                    <TextBlock Text="Aggiornamenti" Style="{StaticResource Eyebrow}"/>
                    <Grid Margin="0,8,0,9"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="132"/></Grid.ColumnDefinitions><TextBlock Text="Canale release" VerticalAlignment="Center"/><ComboBox Grid.Column="1" SelectedValuePath="Content" SelectedValue="{Binding UpdateChannel, Mode=TwoWay}"><ComboBoxItem Content="Stable"/><ComboBoxItem Content="Beta"/></ComboBox></Grid>
                    <CheckBox Content="Controlla all'avvio" IsChecked="{Binding CheckForUpdates, Mode=TwoWay}" Margin="0,2,0,5"/>
                    <TextBlock Text="Controlla soltanto il manifest. Download e installazione richiedono conferma." Style="{StaticResource MutedText}" TextWrapping="Wrap" FontSize="11"/>
                    <Button Content="Salva preferenze" Click="SaveUiPreferences_Click" Style="{StaticResource PrimaryButton}" Margin="0,16,0,0"/>
                    <Button Content="Riapri configurazione guidata" Click="ReopenOnboarding_Click" Margin="0,8,0,0"/>
                    <Button Content="Informazioni e aggiornamenti" Click="ShowAbout_Click" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Popup>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SourcesColumn" Width="260" MinWidth="0" MaxWidth="520" />
                <ColumnDefinition x:Name="SourceSplitterColumn" Width="5" />
                <ColumnDefinition Width="*" MinWidth="430" />
                <ColumnDefinition x:Name="InspectorSplitterColumn" Width="5" />
                <ColumnDefinition x:Name="InspectorColumn" Width="390" MinWidth="0" MaxWidth="680" />
            </Grid.ColumnDefinitions>

            <!-- Project sources -->
            <Border Grid.Column="0" Background="#E9090D13" BorderBrush="#263142" BorderThickness="0,0,1,0" Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Progetto" Style="{StaticResource Eyebrow}" />
                        <TextBlock Text="Sorgenti" FontSize="22" FontWeight="SemiBold" Margin="0,5,0,4" />
                        <TextBlock Text="FITS/XISF sorgenti" Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Grid Grid.Row="1" Margin="0,18,0,8"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Button Content="+ Cartella" Click="AddSource_Click" Margin="0,0,3,0" ToolTip="Importa ricorsivamente FITS e XISF da qualunque software di acquisizione" IsEnabled="{Binding CanRunProjectOperations}" />
                        <Button Grid.Column="1" Content="+ File" Click="AddFiles_Click" Margin="3,0" ToolTip="Importa uno o più file FITS/XISF individuali" IsEnabled="{Binding CanRunProjectOperations}" />
                        <Button Grid.Column="2" Content="Rimuovi" Click="RemoveSource_Click" Margin="3,0,0,0" IsEnabled="{Binding CanRunProjectOperations}" />
                    </Grid>
                    <ListBox x:Name="SourcesList" Grid.Row="2" ItemsSource="{Binding SourcePaths}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text}" MaxHeight="190" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" CornerRadius="8" Padding="9" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12" />
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="3" Margin="0,16,0,0">
                        <TextBlock Text="Librerie di calibrazione" Style="{StaticResource MetaLabel}" />
                        <ListBox x:Name="MasterLibrariesList" ItemsSource="{Binding MasterLibraries}" SelectedItem="{Binding SelectedMasterLibrary}" Background="Transparent" BorderThickness="0" MaxHeight="170" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate><DataTemplate><Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,5"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="22"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><CheckBox IsChecked="{Binding Enabled}" VerticalAlignment="Center" ToolTip="Includi questa libreria nell'analisi"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding Path}" Style="{StaticResource MutedText}" FontSize="9" TextTrimming="CharacterEllipsis"/></StackPanel><StackPanel Grid.Column="2" Margin="7,0,0,0"><TextBlock Text="{Binding PriorityLabel}" Foreground="{StaticResource Accent}" FontSize="9" TextAlignment="Right"/><TextBlock Text="{Binding Status}" Style="{StaticResource MutedText}" FontSize="9" TextAlignment="Right"/></StackPanel></Grid></Border></DataTemplate></ListBox.ItemTemplate>
                        </ListBox>
                        <Grid Margin="0,3,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Button Content="+" Click="ChooseLibrary_Click" ToolTip="Aggiungi libreria" Style="{StaticResource CompactIconButton}" Margin="0,0,3,0"/><Button Grid.Column="1" Content="−" Click="RemoveLibrary_Click" ToolTip="Rimuovi dal progetto" Style="{StaticResource CompactIconButton}" Margin="3,0"/><Button Grid.Column="2" Content="↑" Click="MoveLibraryUp_Click" ToolTip="Aumenta priorità" Style="{StaticResource CompactIconButton}" Margin="3,0"/><Button Grid.Column="3" Content="↓" Click="MoveLibraryDown_Click" ToolTip="Riduci priorità" Style="{StaticResource CompactIconButton}" Margin="3,0,0,0"/></Grid>
                        <Button Content="Aggiorna stato librerie" Click="RefreshLibraries_Click" Margin="0,7,0,0" />
                        <Border Style="{StaticResource Card}" Padding="11" Margin="0,8,0,0" Background="{StaticResource RaisedSurface}">
                            <StackPanel>
                        <TextBlock Text="Valori predefiniti" Style="{StaticResource Eyebrow}"/>
                        <TextBlock Text="Usati solo quando il metadato manca." Style="{StaticResource MutedText}" TextWrapping="Wrap" FontSize="10" Margin="0,4,0,6"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="76"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="42"/><RowDefinition Height="42"/></Grid.RowDefinitions>
                                    <TextBlock Text="Gain" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding ProjectDefaultGain, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="0,2"/>
                                    <TextBlock Grid.Row="1" Text="Offset" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ProjectDefaultOffset, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="0,2"/>
                                    <TextBlock Grid.Row="2" Text="Setpoint °C" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ProjectDefaultTemperature, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="0,2" ToolTip="Lascia vuoto per usare esclusivamente SET-TEMP, CCD-TEMP o il percorso libreria"/>
                                </Grid>
                                <Button Content="Applica valori e rianalizza" Command="{Binding ApplyProjectDefaultsCommand}" Margin="0,7,0,0" Padding="8,6" ToolTip="Usa questi valori soltanto quando mancano nei metadati"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,14,0,0" Background="{StaticResource RaisedSurface}" BorderBrush="#304155">
                        <StackPanel>
                        <TextBlock Text="Notte astronomica" Style="{StaticResource Eyebrow}" />
                            <Grid Margin="0,7,0,5"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="58"/></Grid.ColumnDefinitions><TextBlock Text="Cambio sessione (ora locale)" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding SessionBoundaryHour, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/></Grid>
                        <TextBlock Text="I file acquisiti prima di quest’ora appartengono alla notte precedente." Style="{StaticResource MutedText}" TextWrapping="Wrap" FontSize="11" />
                        </StackPanel>
                    </Border>
                </Grid>
                </ScrollViewer>
            </Border>

            <GridSplitter x:Name="SourceSplitter" Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#263142" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" DragCompleted="PanelSplitter_DragCompleted" ToolTip="Trascina per ridimensionare Sorgenti"/>

            <!-- Analysis, destination plan and exact WBPP recipe -->
            <Grid Grid.Column="2" Margin="20,16">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Border Style="{StaticResource Card}" Padding="15,11" Margin="0,0,0,12" Background="{StaticResource RaisedSurface}" BorderBrush="#314154">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Stato progetto" Style="{StaticResource Eyebrow}"/><TextBlock Text="{Binding ReadinessText}" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="13"/></StackPanel>
                        <Border Grid.Column="1" Background="#1C222D3A" BorderBrush="#39465A" BorderThickness="1" CornerRadius="10" Padding="11,5" VerticalAlignment="Center" Visibility="{Binding HasAnalysis, Converter={StaticResource BooleanToVisibility}}"><TextBlock Text="{Binding UnresolvedCalibrations, StringFormat={}{0} da verificare}" Foreground="{StaticResource Warning}" FontSize="12"/></Border>
                        <Button Grid.Column="2" Content="{Binding AnalysisActionLabel}" Click="Scan_Click" Style="{StaticResource PrimaryButton}" IsEnabled="{Binding CanAnalyzeProject}" Visibility="{Binding HasAnalysis, Converter={StaticResource BooleanToVisibility}}" Margin="12,0,0,0" Padding="20,10" FontWeight="SemiBold" ToolTip="Rianalizza le sorgenti usando le librerie di calibrazione attive"/>
                    </Grid>
                </Border>

                <TabControl x:Name="WorkspaceTabs" Grid.Row="1" Background="Transparent" BorderThickness="0" TabStripPlacement="Top" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" SelectionChanged="WorkspaceTabs_SelectionChanged">
                    <TabItem Header="Analisi" Tag="Inspector">
                        <Grid Margin="0,14,0,0">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <StackPanel><TextBlock Text="Mappa progetto" Style="{StaticResource Title}"/><TextBlock Text="Filtri, sessioni, notti e calibrazioni assegnate." Style="{StaticResource MutedText}" TextWrapping="Wrap"/></StackPanel>
                            <Grid Grid.Row="1" Margin="0,14,0,10"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="120"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Cerca file, target o filtro" Margin="0,0,8,0" IsEnabled="{Binding HasAnalysis}" />
                                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="9,7" Margin="0,0,8,0"><TextBlock Text="{Binding TotalFiles, StringFormat=FILE  {0}}"/></Border>
                                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="9,7"><TextBlock Text="{Binding TotalIssues, StringFormat=AVVISI  {0}}" Foreground="{StaticResource Warning}"/></Border>
                            </Grid>
                            <Grid Grid.Row="2" Margin="2,0,2,9"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><CheckBox Content="Solo elementi da rivedere" IsChecked="{Binding ShowIssuesOnly}" IsEnabled="{Binding HasAnalysis}"/><TextBlock Grid.Column="1" Text="{Binding OverrideCount, StringFormat={}{0} frame modificati}" Style="{StaticResource MutedText}"/></Grid>
                            <Border Grid.Row="3" Style="{StaticResource Card}" Padding="8">
                                <Grid>
                                    <TreeView ItemsSource="{Binding TreeRoots}" SelectedItemChanged="Tree_SelectedItemChanged" MouseDoubleClick="Tree_MouseDoubleClick" ToolTip="Doppio click per mostrare il file originale" IsHitTestVisible="{Binding HasVisibleTree}" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True"/>
                                    <StackPanel Visibility="{Binding ShowImportPrompt, Converter={StaticResource BooleanToVisibility}}" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560" Margin="28">
                                        <Border Width="54" Height="54" CornerRadius="16" Background="#1B23303D" BorderBrush="#3C4D64" BorderThickness="1" HorizontalAlignment="Center"><Image Source="Assets/astroforge.ico" Width="30" Height="30"/></Border>
                                        <TextBlock Text="Nessuna sorgente" FontFamily="Segoe UI Variable Display" FontSize="25" FontWeight="SemiBold" TextAlignment="Center" Margin="0,17,0,7"/>
                                        <TextBlock Text="Aggiungi file o cartelle FITS/XISF." Style="{StaticResource MutedText}" TextWrapping="Wrap" TextAlignment="Center" LineHeight="20"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,22,0,0">
                                            <Button Content="Scegli cartelle" Click="AddSource_Click" Style="{StaticResource PrimaryButton}" Padding="17,9"/>
                                            <Button Content="Scegli file" Click="AddFiles_Click" Margin="9,0,0,0" Padding="17,9"/>
                                        </StackPanel>
                                        <Border Background="#101923" BorderBrush="{StaticResource Stroke}" BorderThickness="1" CornerRadius="9" Padding="13,9" Margin="0,20,0,0">
                                        <TextBlock Text="Le librerie Dark/Bias si configurano nel pannello Sorgenti." Style="{StaticResource MutedText}" FontSize="11" TextWrapping="Wrap" TextAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                    <Border Visibility="{Binding ShowAnalysisPrompt, Converter={StaticResource BooleanToVisibility}}" Style="{StaticResource Card}" Background="#EE101A25" BorderBrush="#4B647D" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="720" Margin="28" Padding="26">
                                        <Grid>
