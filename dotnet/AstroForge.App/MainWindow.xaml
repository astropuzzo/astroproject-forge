                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="RECUPERO DISPONIBILE" Style="{StaticResource Eyebrow}"/>
                    <TextBlock Text="{Binding RecoverySummary}" Foreground="{StaticResource Text}" TextWrapping="Wrap" FontSize="12" Margin="0,3,12,0"/>
