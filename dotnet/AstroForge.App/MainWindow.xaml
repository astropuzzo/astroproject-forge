                                                        <Button Content="Stessa firma tecnica" Click="AssignCandidateSignature_Click" Margin="6,0,0,0" Padding="9,5" ToolTip="Applica a tutte le notti con camera, gain, offset, temperatura, binning e readout equivalenti; per i Dark anche esposizione"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2"><TextBlock Text="{Binding Scope}" TextAlignment="Right" TextWrapping="Wrap"/><TextBlock Text="{Binding CandidateLabel}" Style="{StaticResource MutedText}" TextAlignment="Right" Margin="0,5,0,0"/></StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate></ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Visibility="{Binding ReviewQueue, Converter={StaticResource EmptyCollectionToVisibility}}" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="430"><Border Width="58" Height="58" CornerRadius="18" Background="#173A3A" HorizontalAlignment="Center"><TextBlock Text="✓" Foreground="{StaticResource Accent}" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Text="Nessuna decisione in sospeso" FontSize="21" FontWeight="SemiBold" TextAlignment="Center" Margin="0,15,0,6"/><TextBlock Text="Dark, Bias e Flat risultano assegnati. Se modifichi metadati, librerie o collegamenti, qui compariranno soltanto i casi che richiedono una scelta." Style="{StaticResource MutedText}" TextWrapping="Wrap" TextAlignment="Center"/></StackPanel>
                            </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="◇  MASTER LIBRARY LAB">
                        <Grid Margin="0,14,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <StackPanel><TextBlock Text="Master Library Lab" Style="{StaticResource Title}"/><TextBlock Text="Strumento indipendente dal progetto WBPP. Scansiona le librerie abilitate, completa i metadati mancanti e crea una nuova libreria normalizzata senza modificare gli originali." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,2,0,12"/></StackPanel>
                            <Grid Grid.Row="1" Margin="0,0,0,10"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Button Grid.ColumnSpan="3" Content="◎  SCANSIONA SOLO LE MASTER LIBRARY" Click="ScanMasterLibraries_Click" HorizontalAlignment="Left" Padding="20,10" FontWeight="SemiBold" IsEnabled="{Binding CanRunProjectOperations}"/>
                                <TextBlock Grid.Row="1" Text="Destinazione nuova libreria" Style="{StaticResource MetaLabel}" Margin="2,9,0,4"/>
