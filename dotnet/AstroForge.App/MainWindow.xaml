                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                        <TextBlock Text="Diagnostica" Style="{StaticResource Eyebrow}"/>
                        <TextBlock Text="Eventi applicazione" Style="{StaticResource Title}" Margin="0,4,0,3"/>
