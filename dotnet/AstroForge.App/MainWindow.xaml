                                                                <DataGridTextColumn Header="Offset" Binding="{Binding Offset}" Width="58"/>
                                                                <DataGridTextColumn Header="Temp." Binding="{Binding Temperature}" Width="70"/>
                                                                <DataGridTextColumn Header="Esp." Binding="{Binding Exposure}" Width="70"/>
                                                                <DataGridTextColumn Header="Bin" Binding="{Binding Binning}" Width="52"/>
                                                                <DataGridTextColumn Header="Readout" Binding="{Binding Readout}" Width="*"/>
                                                                <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="54"/>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </Expander>
                                                    <WrapPanel Margin="0,7,0,0">
                                                        <Button Content="Solo questo Light" Click="AssignCandidate_Click" Padding="9,5"/>
                                                        <Button Content="Tutta la notte" Click="AssignCandidateGroup_Click" Margin="6,0,0,0" Padding="9,5"/>
                                                        <Button Content="Stessa firma tecnica" Click="AssignCandidateSignature_Click" Margin="6,0,0,0" Padding="9,5" ToolTip="Applica a tutte le notti con camera, gain, offset, temperatura, binning e readout equivalenti; per i Dark anche esposizione"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2"><TextBlock Text="{Binding Scope}" TextAlignment="Right" TextWrapping="Wrap"/><TextBlock Text="{Binding CandidateLabel}" Style="{StaticResource MutedText}" TextAlignment="Right" Margin="0,5,0,0"/></StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate></ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Visibility="{Binding ReviewQueue.Count, Converter={StaticResource EmptyCollectionToVisibility}}" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="430"><Border Width="58" Height="58" CornerRadius="18" Background="#173A3A" HorizontalAlignment="Center"><TextBlock Text="✓" Foreground="{StaticResource Accent}" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Text="Nessun problema" FontSize="21" FontWeight="SemiBold" TextAlignment="Center" Margin="0,15,0,6"/><TextBlock Text="Tutte le calibrazioni richieste sono assegnate." Style="{StaticResource MutedText}" TextWrapping="Wrap" TextAlignment="Center"/></StackPanel>
                            </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Libreria Master">
                        <Grid Margin="0,14,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <StackPanel><TextBlock Text="Libreria Master" Style="{StaticResource Title}" Margin="0,4,0,0"/><TextBlock Text="Inventario, metadati e struttura delle copie normalizzate." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,3,0,14"/></StackPanel>
                            <Grid Grid.Row="1" Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="0.38*"/><ColumnDefinition Width="0.62*"/></Grid.ColumnDefinitions>
