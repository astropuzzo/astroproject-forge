        </Grid>

        <Border Grid.Row="1" Panel.ZIndex="30" HorizontalAlignment="Center" VerticalAlignment="Top" MaxWidth="980" Margin="24,18,24,0" Padding="18,14" CornerRadius="14" Background="#F21A241F" BorderBrush="#5DBF99" BorderThickness="1" Effect="{StaticResource SoftShadow}" Visibility="{Binding HasRecoverySnapshot, Converter={StaticResource BooleanToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Border Width="38" Height="38" CornerRadius="11" Background="#243F36" Margin="0,0,13,0"><TextBlock Text="↺" Foreground="{StaticResource Accent}" FontSize="21" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
