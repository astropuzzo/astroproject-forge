                                <ListBox.ItemTemplate><DataTemplate>
                                    <Border Style="{StaticResource Card}" Padding="14">
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="86"/><ColumnDefinition/><ColumnDefinition Width="145"/></Grid.ColumnDefinitions>
                                            <Border Background="#4A2C20" CornerRadius="8" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Top"><TextBlock Text="{Binding Calibration}" Foreground="{StaticResource Warning}" FontWeight="SemiBold"/></Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,14,0"><TextBlock Text="{Binding State}" FontWeight="SemiBold" FontSize="15"/><TextBlock Text="{Binding Frame.FileName}" Style="{StaticResource MutedText}" FontSize="11" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding Reason}" Margin="0,7,0,0" TextWrapping="Wrap"/><TextBlock Text="{Binding SuggestedAction}" Foreground="{StaticResource Accent}" Margin="0,5,0,0" TextWrapping="Wrap" FontSize="11"/>
                                                <StackPanel Margin="0,9,0,0" Visibility="{Binding CanAssignMaster, Converter={StaticResource BooleanToVisibility}}">
                                                    <TextBlock Text="{Binding TargetSignature}" Style="{StaticResource MutedText}" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <ComboBox ItemsSource="{Binding Candidates}" SelectedItem="{Binding SelectedCandidate}" DisplayMemberPath="Display" ToolTip="Scegli il Master da assegnare"/>
                                                    <Expander Header="Confronta i candidati campo per campo" Margin="0,7,0,0">
                                                        <DataGrid ItemsSource="{Binding Candidates}" SelectedItem="{Binding SelectedCandidate, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="190" Margin="0,5,0,0" HeadersVisibility="Column" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single">
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn Header="Master" Binding="{Binding FileName}" Width="2*"/>
                                                                <DataGridTextColumn Header="Camera" Binding="{Binding Camera}" Width="*"/>
                                                                <DataGridTextColumn Header="Gain" Binding="{Binding Gain}" Width="58"/>
                                                                <DataGridTextColumn Header="Offset" Binding="{Binding Offset}" Width="58"/>
                                                                <DataGridTextColumn Header="Temp." Binding="{Binding Temperature}" Width="70"/>
                                                                <DataGridTextColumn Header="Esp." Binding="{Binding Exposure}" Width="70"/>
                                                                <DataGridTextColumn Header="Bin" Binding="{Binding Binning}" Width="52"/>
                                                                <DataGridTextColumn Header="Readout" Binding="{Binding Readout}" Width="*"/>
                                                                <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="54"/>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </Expander>
                                                    <WrapPanel Margin="0,7,0,0">
                                                        <Button Content="Solo questo Light" Click="AssignCandidate_Click" Padding="9,5"/>
