                        <TextBlock Text="{Binding SelectionDetail}" Style="{StaticResource MutedText}" />

                        <Border Margin="0,28,0,0" Padding="24" Background="#68111620" BorderBrush="{StaticResource Stroke}" BorderThickness="1" CornerRadius="14">
