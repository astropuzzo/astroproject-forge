                </TabControl>
            </Grid>

            <GridSplitter x:Name="InspectorSplitter" Grid.Column="3" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#263142" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" DragCompleted="PanelSplitter_DragCompleted" ToolTip="Trascina per ridimensionare Inspector"/>

