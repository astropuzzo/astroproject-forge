                        </StackPanel>
                        <Button Grid.Column="1" Content="×" Click="CloseDiagnostics_Click" Style="{StaticResource ToolbarButton}" Width="42" Height="42" Padding="0" FontSize="20" ToolTip="Chiudi diagnostica"/>
                    </Grid>
                    <Border Grid.Row="1" Background="#172533" BorderBrush="#36546A" BorderThickness="1" CornerRadius="10" Padding="13,9" Margin="28,0,28,12">
                        <TextBlock Text="{Binding DiagnosticsSummary}" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
                    </Border>
                    <DataGrid Grid.Row="2" ItemsSource="{Binding DiagnosticEvents}" IsReadOnly="True" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False" HeadersVisibility="Column" Margin="28,0" MinHeight="260" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ora" Binding="{Binding Timestamp}" Width="118"/>
                            <DataGridTextColumn Header="Livello" Binding="{Binding Level}" Width="88"/>
                            <DataGridTextColumn Header="Codice" Binding="{Binding Code}" Width="150"/>
                            <DataGridTextColumn Header="Operazione" Binding="{Binding Operation}" Width="180"/>
                            <DataGridTextColumn Header="ID" Binding="{Binding Correlation}" Width="78"/>
                            <DataGridTextColumn Header="Evento" Binding="{Binding Message}" Width="*"/>
                            <DataGridTextColumn Header="Eccezione" Binding="{Binding ExceptionType}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Grid Grid.Row="3" Margin="28,16,28,24">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="I dati restano sul computer finché non scegli esplicitamente Esporta ZIP." Style="{StaticResource MutedText}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        <Button Grid.Column="1" Content="Aggiorna eventi" Click="RefreshDiagnostics_Click" Margin="12,0,8,0" Padding="16,9"/>
                        <Button Grid.Column="2" Content="Esporta ZIP privacy-safe" Click="ExportSupportFromDiagnostics_Click" Style="{StaticResource PrimaryButton}" Padding="18,9"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="AboutOverlay" Grid.RowSpan="3" Panel.ZIndex="90" Background="#E6070B12" Visibility="Collapsed">
            <Ellipse Width="620" Height="620" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-330,-240,0" IsHitTestVisible="False"><Ellipse.Fill><RadialGradientBrush><GradientStop Color="#422DD8C9" Offset="0"/><GradientStop Color="#002DD8C9" Offset="1"/></RadialGradientBrush></Ellipse.Fill></Ellipse>
            <Border Width="720" MaxHeight="650" Margin="28" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource Card}" Background="#FA0D1622" BorderBrush="#5B7894" Padding="0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="7"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Border CornerRadius="16,16,0,0" Background="{StaticResource AccentGradient}"/>
                    <Grid Grid.Row="1" Margin="30,25,30,18"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="ASTROPROJECT FORGE" Style="{StaticResource Eyebrow}"/><TextBlock Text="Informazioni" Style="{StaticResource Title}" Margin="0,5,0,4"/><TextBlock Text="Preparazione di progetti multisessione per PixInsight WBPP." Style="{StaticResource MutedText}" TextWrapping="Wrap"/></StackPanel><Button Grid.Column="1" Content="×" Click="CloseAbout_Click" Style="{StaticResource ToolbarButton}" Width="42" Height="42" Padding="0" FontSize="20" ToolTip="Chiudi"/></Grid>
                    <Grid Grid.Row="2" Margin="30,0,30,18"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Background="#102725" Margin="0,0,7,0"><StackPanel><TextBlock Text="Versione" Style="{StaticResource Eyebrow}"/><TextBlock Text="{Binding VersionDisplay}" FontSize="25" FontWeight="SemiBold" Margin="0,6,0,3"/></StackPanel></Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}" Background="#101F2A" Margin="7,0,0,0"><StackPanel><TextBlock Text="Canale" Style="{StaticResource Eyebrow}"/><TextBlock Text="{Binding UpdateChannel}" FontSize="25" FontWeight="SemiBold" Margin="0,6,0,3"/><TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource MutedText}" TextWrapping="Wrap" FontSize="11"/></StackPanel></Border>
                    </Grid>
                    <StackPanel Grid.Row="3" Margin="30,0,30,28">
                        <Border Background="#141D2A" BorderBrush="{StaticResource Stroke}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,15"><TextBlock Text="Gli aggiornamenti sono verificati con dimensione, SHA-256 e firma Authenticode valida. Il programma non avvia mai automaticamente un installer. I progetti e le immagini astronomiche restano fuori dal percorso di disinstallazione." Style="{StaticResource MutedText}" TextWrapping="Wrap" LineHeight="19"/></Border>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Release 0.9: QA riproducibile, packaging per utente e canali Stable/Beta." Style="{StaticResource MutedText}" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,15,0"/><Button x:Name="DownloadUpdateButton" Grid.Column="1" Content="Scarica aggiornamento verificato" Click="DownloadUpdate_Click" Visibility="Collapsed" Margin="0,0,9,0"/><Button Grid.Column="2" Content="Controlla ora" Click="CheckUpdates_Click" Style="{StaticResource PrimaryButton}" MinWidth="130"/></Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#D0090D14" BorderBrush="#34465D" BorderThickness="0,1,0,0">
            <Grid Margin="14,0"><TextBlock Text="{Binding Status}" Style="{StaticResource MutedText}" VerticalAlignment="Center"/><ProgressBar Width="220" Height="4" HorizontalAlignment="Right" VerticalAlignment="Center" Value="{Binding Progress, Mode=OneWay}" Maximum="100" Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibility}}" Foreground="{StaticResource Accent}" Background="{StaticResource Bg3}"/></Grid>
        </Border>

        <Grid x:Name="OnboardingOverlay" Grid.RowSpan="3" Background="#E6060910" Visibility="{Binding ShowOnboarding, Converter={StaticResource BooleanToVisibility}}">
            <Ellipse Width="760" Height="760" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-470,-360,0" IsHitTestVisible="False"><Ellipse.Fill><RadialGradientBrush><GradientStop Color="#4A2DD8C9" Offset="0"/><GradientStop Color="#002DD8C9" Offset="1"/></RadialGradientBrush></Ellipse.Fill></Ellipse>
            <Border Width="780" MaxHeight="620" Margin="28" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource Card}" Background="#F20C1420" BorderBrush="#627B96" Padding="0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="8"/><RowDefinition Height="*"/><RowDefinition Height="82"/></Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="16,16,0,0" Background="{StaticResource AccentGradient}"/>
                    <Grid Grid.Row="1" Margin="42,34,42,18">
                        <StackPanel x:Name="OnboardingStep1">
                    <TextBlock Text="Configurazione iniziale" Style="{StaticResource Eyebrow}"/>
                    <TextBlock Text="Prepara il primo progetto" FontSize="38" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display" Margin="0,10,0,12"/>
                    <TextBlock Text="Configura librerie di calibrazione, notte astronomica e sorgenti FITS/XISF." Style="{StaticResource MutedText}" FontSize="15" LineHeight="24" TextWrapping="Wrap" MaxWidth="650" HorizontalAlignment="Left"/>
                            <Grid Margin="0,28,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource Card}" Margin="0,0,8,0" Background="#102725"><StackPanel><TextBlock Text="01" Style="{StaticResource Eyebrow}"/><TextBlock Text="Importa" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,3"/><TextBlock Text="FITS e XISF" Style="{StaticResource MutedText}"/></StackPanel></Border>
                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4,0" Background="#101F2A"><StackPanel><TextBlock Text="02" Style="{StaticResource Eyebrow}"/><TextBlock Text="Verifica" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,3"/><TextBlock Text="metadati e calibrazioni" Style="{StaticResource MutedText}"/></StackPanel></Border>
                    <Border Grid.Column="2" Style="{StaticResource Card}" Margin="8,0,0,0" Background="#102725"><StackPanel><TextBlock Text="03" Style="{StaticResource Eyebrow}"/><TextBlock Text="Esporta" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,3"/><TextBlock Text="progetto WBPP" Style="{StaticResource MutedText}"/></StackPanel></Border>
                            </Grid>
                        </StackPanel>
                        <StackPanel x:Name="OnboardingStep2" Visibility="Collapsed">
                    <TextBlock Text="Passo 1 · Librerie" Style="{StaticResource Eyebrow}"/>
                    <TextBlock Text="Aggiungi Dark e Bias" FontSize="32" FontWeight="SemiBold" Margin="0,8,0,10"/>
                    <TextBlock Text="Puoi aggiungere più librerie e ordinarle per priorità." Style="{StaticResource MutedText}" FontSize="14" LineHeight="22" TextWrapping="Wrap"/>
                            <Border Style="{StaticResource Card}" Background="#102725" Margin="0,24,0,14"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="LIBRERIE COLLEGATE" Style="{StaticResource Eyebrow}"/><TextBlock Text="{Binding MasterLibraries.Count, StringFormat={}{0} configurate}" FontSize="21" FontWeight="SemiBold" Margin="0,6,0,0"/></StackPanel><Button Grid.Column="1" Content="+ Scegli cartella Master" Click="OnboardingChooseLibrary_Click" Style="{StaticResource PrimaryButton}"/></Grid></Border>
                    <TextBlock Text="Le librerie possono essere modificate in seguito." Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel x:Name="OnboardingStep3" Visibility="Collapsed">
                    <TextBlock Text="Passo 2 · Acquisizione" Style="{StaticResource Eyebrow}"/>
                    <TextBlock Text="Imposta i valori mancanti" FontSize="32" FontWeight="SemiBold" Margin="0,8,0,10"/>
                    <TextBlock Text="I valori predefiniti vengono usati solo quando il metadato non è disponibile." Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
                            <Grid Margin="0,24,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0"><TextBlock Text="Cambio notte (ora locale)" Style="{StaticResource MetaLabel}"/><TextBox Text="{Binding SessionBoundaryHour, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/></StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0"><TextBlock Text="Gain predefinito" Style="{StaticResource MetaLabel}"/><TextBox Text="{Binding ProjectDefaultGain, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/></StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0"><TextBlock Text="Offset predefinito" Style="{StaticResource MetaLabel}"/><TextBox Text="{Binding ProjectDefaultOffset, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/></StackPanel>
                            </Grid>
                            <Border Style="{StaticResource Card}" Background="#101F2A" Margin="0,22,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="SORGENTI FITS / XISF" Style="{StaticResource Eyebrow}"/><TextBlock Text="{Binding SourcePaths.Count, StringFormat={}{0} sorgenti importate}" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0"/><TextBlock Text="N.I.N.A., ASIAIR, SGP, Voyager, SharpCap o altri software" Style="{StaticResource MutedText}" FontSize="10"/></StackPanel><Button Grid.Column="1" Content="+ File" Click="OnboardingAddFiles_Click" Margin="8,0,0,0"/><Button Grid.Column="2" Content="+ Cartelle" Click="OnboardingAddSource_Click" Margin="8,0,0,0"/></Grid></Border>
                        </StackPanel>
                        <StackPanel x:Name="OnboardingStep4" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="590">
                            <Border Width="74" Height="74" CornerRadius="23" Background="{StaticResource AccentGradient}" HorizontalAlignment="Center" Effect="{StaticResource AccentGlow}"><TextBlock Text="✓" Foreground="#071411" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    <TextBlock Text="Configurazione completata" FontSize="34" FontWeight="SemiBold" TextAlignment="Center" Margin="0,20,0,10"/>
                    <TextBlock Text="Avvia l’analisi per costruire la mappa del progetto." Style="{StaticResource MutedText}" FontSize="14" LineHeight="22" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="2" Background="#C9121C29" BorderBrush="#40536B" BorderThickness="0,1,0,0" CornerRadius="0,0,16,16">
                        <Grid Margin="28,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><TextBlock x:Name="OnboardingProgress" Text="1 / 4" Style="{StaticResource Eyebrow}"/><Button Content="Salta configurazione" Click="OnboardingSkip_Click" Padding="10,5" Margin="14,0,0,0" Background="Transparent" BorderThickness="0"/></StackPanel>
                            <Button x:Name="OnboardingBackButton" Grid.Column="1" Content="Indietro" Click="OnboardingBack_Click" Visibility="Collapsed" Margin="0,0,10,0" MinWidth="110"/>
                            <Button x:Name="OnboardingNextButton" Grid.Column="2" Content="Inizia" Click="OnboardingNext_Click" Style="{StaticResource PrimaryButton}" MinWidth="140"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
