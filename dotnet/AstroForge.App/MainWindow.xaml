            <Border Grid.Column="4" Background="#E9090D13" BorderBrush="#263142" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Inspector" Style="{StaticResource Eyebrow}" />
