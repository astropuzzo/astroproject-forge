                                            <Grid><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="1.2*"/><ColumnDefinition Width="0.8*"/><ColumnDefinition Width="1.3*"/><ColumnDefinition Width="1.3*"/></Grid.ColumnDefinitions>
                                                <StackPanel><TextBlock Text="{Binding Filter}" FontSize="18" FontWeight="SemiBold"/><StackPanel Orientation="Horizontal" Margin="0,5,0,0"><Border Background="#172A32" CornerRadius="8" Padding="7,3" Margin="0,0,5,0"><TextBlock Text="{Binding Gain}" Foreground="{StaticResource Accent}" FontSize="10"/></Border><Border Background="#172130" CornerRadius="8" Padding="7,3"><TextBlock Text="{Binding Temperature}" Style="{StaticResource MutedText}" FontSize="10"/></Border></StackPanel></StackPanel>
                                                <StackPanel Grid.Column="1"><TextBlock Text="{Binding Integration}" Foreground="{StaticResource Accent}" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="{Binding Lights, StringFormat={}{0} Light}" Style="{StaticResource MutedText}" FontSize="11"/></StackPanel>
                                                <StackPanel Grid.Column="2"><TextBlock Text="{Binding NightsLabel}"/><TextBlock Text="{Binding SessionsLabel}" Style="{StaticResource MutedText}" FontSize="11"/></StackPanel>
                                                <StackPanel Grid.Column="3"><TextBlock Text="{Binding Status}"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource Warning}"/><Style.Triggers><DataTrigger Binding="{Binding Ready}" Value="True"><Setter Property="Foreground" Value="{StaticResource Accent}"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock><TextBlock Text="{Binding Calibration}" Style="{StaticResource MutedText}" FontSize="11" TextWrapping="Wrap"/></StackPanel>
                                                <ProgressBar Grid.Row="2" Grid.ColumnSpan="4" Value="{Binding Percentage, Mode=OneWay}" Maximum="100" Height="5" Margin="0,11,0,0" Foreground="{StaticResource Accent}" Background="{StaticResource Bg3}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="SESSIONI DI CONFIGURAZIONE" Style="{StaticResource Eyebrow}" Margin="2,12,0,8"/>
