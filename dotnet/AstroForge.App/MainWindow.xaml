                                    <DataGridTextColumn Header="CAMERA" Binding="{Binding Camera, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                                    <DataGridTextColumn Header="GAIN" Binding="{Binding Gain, UpdateSourceTrigger=PropertyChanged}" Width="65"/>
                                    <DataGridTextColumn Header="OFFSET" Binding="{Binding Offset, UpdateSourceTrigger=PropertyChanged}" Width="65"/>
                                    <DataGridTextColumn Header="TEMP °C" Binding="{Binding Temperature, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                    <DataGridTextColumn Header="EXP s" Binding="{Binding Exposure, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                    <DataGridTextColumn Header="STATO" Binding="{Binding State}" IsReadOnly="True" Width="1.2*"/>
                                    <DataGridTextColumn Header="VERIFICA" Binding="{Binding Preflight}" IsReadOnly="True" Width="1.3*"/>
                                    <DataGridTextColumn Header="DESTINAZIONE" Binding="{Binding SuggestedPath}" IsReadOnly="True" Width="2*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Visibility="{Binding MasterOrganizerItems.Count, Converter={StaticResource EmptyCollectionToVisibility}}" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500"><Border Width="52" Height="52" CornerRadius="16" Background="#1B23303D" HorizontalAlignment="Center"><TextBlock Text="◎" Foreground="{StaticResource Violet}" FontSize="23" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Text="Nessun Master analizzato" FontSize="21" FontWeight="SemiBold" TextAlignment="Center" Margin="0,15,0,6"/><TextBlock Text="Avvia la scansione per leggere metadati e destinazioni proposte." Style="{StaticResource MutedText}" TextWrapping="Wrap" TextAlignment="Center" LineHeight="20"/></StackPanel>
                            </Grid>
                        </Grid>
