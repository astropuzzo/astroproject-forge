                                <Border Grid.Column="1" Style="{StaticResource Card}" Background="{StaticResource RaisedSurface}" Margin="6,0,0,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="02 · VERIFICA E DESTINAZIONE" Style="{StaticResource Eyebrow}"/><TextBlock Text="{Binding MasterOrganizerStatus}" Foreground="{StaticResource Text}" FontSize="12" Margin="0,5,12,8" TextWrapping="Wrap"/></StackPanel><Button Grid.Column="1" Content="Annulla ultimo batch" Click="RollbackMasterOrganizer_Click" Width="142" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="10,6" IsEnabled="{Binding CanRunProjectOperations}" ToolTip="Rimuove soltanto le copie dell’ultimo batch se non sono state modificate"/><TextBox Grid.Row="1" Text="{Binding MasterOrganizerDestination}" IsReadOnly="True" ToolTip="Destinazione nuova Libreria Master"/><StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0"><Button Content="Destinazione" Click="ChooseMasterOrganizerDestination_Click" Padding="10,7"/><Button Content="Verifica" Click="PreviewMasterOrganizer_Click" Margin="7,0,0,0" Padding="10,7" IsEnabled="{Binding CanRunProjectOperations}" ToolTip="Controlla metadati e destinazioni senza copiare file"/><Button Content="Organizza copie" Click="OrganizeMasterLibrary_Click" Style="{StaticResource PrimaryButton}" Margin="7,0,0,0" Padding="12,7" IsEnabled="{Binding CanRunProjectOperations}" ToolTip="Crea copie ordinate e completa i metadati confermati"/></StackPanel></Grid></Border>
                            </Grid>
                            <Grid Grid.Row="2">
                            <DataGrid x:Name="MasterOrganizerGrid" ItemsSource="{Binding MasterOrganizerItems}" MouseDoubleClick="MasterOrganizerGrid_MouseDoubleClick" ToolTip="Doppio click per mostrare il Master originale" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" Background="{StaticResource Bg1}" Foreground="{StaticResource Text}" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource Stroke}" RowBackground="{StaticResource Bg2}" AlternatingRowBackground="#101824">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="MASTER" Binding="{Binding FileName}" IsReadOnly="True" Width="1.5*"/>
